generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedJob {
  id          String   @id @default(cuid())
  title       String
  company     String?
  location    String?
  type        String?
  salary      String?
  description String?
  url         String
  source      String?
  postedDate  String?
  deadline    String?
  category    String?
  isBookmarked Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())
  jobId       String?
  jobTitle    String
  company     String?
  location    String?
  status      String   @default("pending_review") // pending_review, approved, submitted, interview, offered, rejected, withdrawn
  url         String?
  coverLetter String?
  matchReasoning String?
  jobDeadline String?
  jobDescription String?
  notes       String?
  matchScore  Int?
  source      String?
  appliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserProfile {
  id          String   @id @default(cuid())
  fullName    String?
  email       String?
  phone       String?
  location    String?
  title       String?
  summary     String?
  skills      String   // JSON array string
  education   String?  // JSON array string
  experience  String?  // JSON array string
  resumeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user, assistant
  content   String
  createdAt DateTime @default(now())
}
