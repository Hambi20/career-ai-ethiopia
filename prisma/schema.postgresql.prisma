// PostgreSQL schema for Vercel deployment (Vercel Postgres / Neon)
// Usage: prisma generate --schema prisma/schema.postgresql.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String?
  phone         String?
  avatar        String?
  role          String   @default("jobseeker")
  tier          String   @default("free")
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile     UserProfile?
  applications Application[]
  chatMessages ChatMessage[]
  cvAnalyses  CvAnalysis[]
  interviewPreps InterviewPrep[]
  savedJobs   SavedJob[]
  postedJobs  EmployerJob[]
  usageLogs   UsageLog[]
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model EmployerJob {
  id          String   @id @default(cuid())
  userId      String
  title       String
  company     String?
  location    String?
  type        String?
  salary      String?
  category    String?
  description String
  requirements String?
  deadline    String?
  status      String   @default("active")
  applicants  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model SavedJob {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  company     String?
  location    String?
  type        String?
  salary      String?
  description String?
  url         String
  source      String?
  postedDate  String?
  deadline    String?
  category    String?
  isBookmarked Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Application {
  id          String   @id @default(cuid())
  userId      String?
  jobId       String?
  jobTitle    String
  company     String?
  location    String?
  status      String   @default("pending_review")
  url         String?
  coverLetter String?
  matchReasoning String?
  jobDeadline String?
  jobDescription String?
  notes       String?
  matchScore  Int?
  source      String?
  appliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String?
  fullName    String?
  email       String?
  phone       String?
  location    String?
  title       String?
  summary     String?
  skills      String
  education   String?
  experience  String?
  resumeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String?
  role      String
  content   String
  createdAt DateTime @default(now())
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CvAnalysis {
  id              String   @id @default(cuid())
  userId          String?
  overallScore    Int
  strengths       String
  weaknesses      String
  missingSkills   String
  atsScore        Int
  formatScore     Int
  contentScore    Int
  suggestions     String
  industryTips    String?
  recommendation  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model BotReport {
  id        String   @id @default(cuid())
  type      String   @default("general")
  company   String   @default("")
  category  String   @default("general")
  title     String
  content   String   @default("")
  summary   String   @default("")
  chatId    Int      @default(0)
  firstName String   @default("")
  date      String   @default("")
  timestamp String   @default("")
  createdAt DateTime @default(now())
  @@index([type])
  @@index([company])
  @@index([date])
  @@index([createdAt])
}

model InterviewPrep {
  id              String   @id @default(cuid())
  userId          String?
  jobTitle        String?
  company         String?
  jobDescription  String?
  questions       String
  companyResearch String?
  tips            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
